{
  "name": "thesis-studio",
  "version": "1.0.0",
  "description": "Structured AI-assisted workspace template for long-form academic writing — dissertation, journal article, or master's thesis from one root.",
  "private": false,
  "license": "MIT",
  "homepage": "https://github.com/estevanhernandez-stack-ed/ThesisStudio",
  "repository": {
    "type": "git",
    "url": "https://github.com/estevanhernandez-stack-ed/ThesisStudio.git"
  },
  "author": "626Labs",
  "scripts": {
    "render:pdf": "node scripts/render-pdf.js",
    "render:latex": "node scripts/render-latex.js",
    "render:markdown": "node scripts/render-markdown.js",
    "render:html": "node scripts/render-html.js",
    "render:all": "npm run render:markdown && npm run render:html && npm run render:latex && npm run render:pdf",
    "compile:tokens": "node scripts/compile-tokens.js",
    "validate": "node scripts/validate-schemas.js",
    "check:citations": "node scripts/check-citations.js",
    "check:links": "linkinator . --skip 'node_modules|08_OUTPUT|.git'",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#08_OUTPUT\"",
    "export:portable": "node scripts/export-portable.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@retorquere/bibtex-parser": "^9.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "lint-staged": "^15.2.10",
    "linkinator": "^7.0.0",
    "markdownlint-cli2": "^0.22.1"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.md": [
      "markdownlint-cli2"
    ],
    "*.{yaml,yml,json}": [
      "node scripts/validate-schemas.js"
    ]
  }
}
