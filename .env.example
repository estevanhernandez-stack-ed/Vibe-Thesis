# Vibe Thesis — Environment Variables
#
# The plugin itself requires NO environment variables. This file documents
# the env vars that scaffolded projects may optionally set.
#
# Copy to .env (in your scaffolded project, NOT the plugin repo) and uncomment
# only the vars you need.

# Optional: explicit paths to toolchain binaries if they're not on PATH.
# Most users won't need these — the dev container has them on PATH, and native
# installs typically place them on PATH.
#
# BIBER_PATH=/usr/bin/biber
# PANDOC_PATH=/usr/local/bin/pandoc
# XELATEX_PATH=/usr/bin/xelatex

# Optional: override the GitHub template repo for Path B (e.g., to use a fork).
# Default: estevanhernandez-stack-ed/ThesisStudio
#
# VIBE_THESIS_TEMPLATE_REPO=your-org/your-thesisstudio-fork

# Optional: synthesis-guard configuration.
# GUARD_PROFILE values: standard (default), strict, off
#
# GUARD_PROFILE=standard
